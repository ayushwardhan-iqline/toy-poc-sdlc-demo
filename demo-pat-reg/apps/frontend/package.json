{
  "name": "@demo-pat-reg/frontend",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/vite:build",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "outputPath": "apps/frontend/dist"
        },
        "configurations": {
          "development": {
            "mode": "development"
          },
          "production": {
            "mode": "production"
          }
        }
      },
      "serve": {
        "executor": "@nx/vite:dev-server",
        "defaultConfiguration": "development",
        "options": {
          "buildTarget": "@demo-pat-reg/frontend:build"
        },
        "configurations": {
          "development": {
            "buildTarget": "@demo-pat-reg/frontend:build:development"
          },
          "production": {
            "buildTarget": "@demo-pat-reg/frontend:build:production"
          }
        }
      },
      "preview": {
        "executor": "@nx/vite:preview-server",
        "defaultConfiguration": "development",
        "options": {
          "buildTarget": "@demo-pat-reg/frontend:build"
        },
        "configurations": {
          "development": {
            "buildTarget": "@demo-pat-reg/frontend:build:development"
          },
          "production": {
            "buildTarget": "@demo-pat-reg/frontend:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      }
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@demo-pat-reg/shared": "0.0.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "shadcn": "^4.0.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@nx/react": "22.5.4",
    "@nx/vite": "22.5.4",
    "@tailwindcss/vite": "^4.2.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.2.1",
    "vite": "^7.0.0"
  }
}
