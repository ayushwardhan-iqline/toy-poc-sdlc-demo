{
  "name": "@demo-pat-reg/backend-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@demo-pat-reg/backend"
    ],
    "targets": {
      "e2e": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bunx vitest run",
          "cwd": "apps/backend-e2e"
        },
        "outputs": [
          "{projectRoot}/test-output/vitest/coverage"
        ],
        "dependsOn": [
          "@demo-pat-reg/backend:build",
          "@demo-pat-reg/backend:serve"
        ]
      }
    }
  }
}
