{
  "name": "@demo-pat-reg/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:seed": "bun run apps/backend/src/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "nx": "nx",
    "ci:check-base-sync": "bun ./scripts/ensure-base-synced.mjs",
    "ci:full:static-analysis:eslint": "bunx nx run-many -t lint --parallel=3",
    "ci:full:static-analysis:semgrep": "bun ./scripts/run-semgrep.mjs",
    "ci:full:static-analysis": "bun run ci:full:static-analysis:eslint && bun run ci:full:static-analysis:semgrep",
    "ci:full:typecheck": "bunx nx run-many -t typecheck --parallel=3",
    "ci:full:test:unit": "bunx nx run-many -t test --parallel=2",
    "ci:full:test:coverage": "bunx nx run-many -t test --coverage --parallel=2",
    "ci:full:test:integration": "bunx nx run-many -t test:integration",
    "ci:full:test:e2e": "bunx nx run-many -t e2e",
    "ci:full:deterministic": "bun run ci:full:static-analysis && bun run ci:full:typecheck && bun run ci:full:test:unit && bun run ci:full:test:coverage && bun run ci:full:test:integration",
    "ci:full:ai:review": "bun ./scripts/run-ai-review-step7.mjs --mode=full",
    "ci:full:ai:judge-e2e": "bun ./scripts/run-ai-e2e-judge.mjs --mode=full",
    "ci:full:all": "bun run ci:full:deterministic && bun run ci:full:ai:review",
    "ci:full:with-e2e-judge": "bun run ci:full:all && bun run ci:full:test:e2e && bun run ci:full:ai:judge-e2e",
    "ci:affected:static-analysis:eslint": "bunx nx affected -t lint --parallel=3",
    "ci:affected:static-analysis:semgrep": "bun ./scripts/run-semgrep.mjs --affected",
    "ci:affected:static-analysis": "bun run ci:affected:static-analysis:eslint && bun run ci:affected:static-analysis:semgrep",
    "ci:affected:typecheck": "bunx nx affected -t typecheck --parallel=3",
    "ci:affected:test:unit": "bunx nx affected -t test --parallel=2",
    "ci:affected:test:coverage": "bunx nx affected -t test --coverage --parallel=2",
    "ci:affected:test:integration": "bunx nx affected -t test:integration",
    "ci:affected:test:e2e": "bunx nx affected -t e2e",
    "ci:affected:deterministic": "bun run ci:affected:static-analysis && bun run ci:affected:typecheck && bun run ci:affected:test:unit && bun run ci:affected:test:coverage && bun run ci:affected:test:integration",
    "ci:affected:ai:review": "bun ./scripts/run-ai-review-step7.mjs --mode=affected",
    "ci:affected:ai:judge-e2e": "bun ./scripts/run-ai-e2e-judge.mjs --mode=affected",
    "ci:affected:all": "bun run ci:affected:deterministic && bun run ci:affected:ai:review",
    "ci:affected:with-e2e-judge": "bun run ci:affected:all && bun run ci:affected:test:e2e && bun run ci:affected:ai:judge-e2e",
    "ci:static-analysis": "bun run ci:full:static-analysis",
    "ci:typecheck": "bun run ci:full:typecheck",
    "ci:test:unit": "bun run ci:full:test:unit",
    "ci:test:coverage": "bun run ci:full:test:coverage",
    "ci:test:integration": "bun run ci:full:test:integration",
    "ci:deterministic": "bun run ci:full:deterministic",
    "ci:all": "bun run ci:full:all",
    "ci:pr": "bun run ci:affected:all",
    "ci:pr:with-e2e-judge": "bun run ci:affected:with-e2e-judge",
    "ci:local:pr": "act pull_request -W ../.github/workflows/ci.yml --secret-file .secrets",
    "test:scripts": "vitest run -c ./scripts/vitest.config.ts ./scripts"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "express": "^4.21.2",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@ngneat/falso": "^8.0.2",
    "@nx/devkit": "22.5.4",
    "@nx/docker": "22.5.4",
    "@nx/esbuild": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/node": "22.5.4",
    "@nx/playwright": "22.5.4",
    "@nx/react": "^22.5.4",
    "@nx/vite": "22.5.4",
    "@nx/web": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/ui": "^4.0.0",
    "autoprefixer": "10.4.20",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.19.2",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "22.5.4",
    "postcss": "8.5.1",
    "prettier": "~3.6.2",
    "tailwindcss": "3.4.17",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  },
  "workspaces": [
    "apps/*",
    "apps-e2e",
    "libs"
  ]
}
