# Local secrets for running GitHub Actions via act.
# Save your real values in .secrets (ignored by git).

# GitHub token is commonly needed by actions/checkout in act.
GITHUB_TOKEN=replace-with-your-token

# OpenCode credentials used by Step 7 and Step 8.5.
OPENCODE_API_KEY=replace-with-your-opencode-api-key
OPENCODE_MODEL=opencode/minimax-m2.5-free

# Optional examples for private package registries or external services:
# NODE_AUTH_TOKEN=
# NPM_TOKEN=
